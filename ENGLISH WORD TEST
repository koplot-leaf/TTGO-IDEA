const int totalWords = sizeof(vocab) / sizeof(WordItem);
int queue[totalWords];
int head = 0;
bool needRedraw = true;

void setup() {
  tft.init();
  tft.setRotation(1);
  pinMode(btnLeft, INPUT_PULLUP);
  pinMode(btnRight, INPUT_PULLUP);
  
  for(int i=0; i<totalWords; i++) queue[i] = i;
}

void loop() {
  if (needRedraw) {
    drawUI();
    needRedraw = false;
  }

  // 왼쪽: 모름 (3개 뒤로 밀기)
  if (digitalRead(btnLeft) == LOW) {
    delay(200); 
    pushBack(3);
    needRedraw = true;
  }

  // 오른쪽: 앎 (다음 단어)
  if (digitalRead(btnRight) == LOW) {
    delay(200);
    head++;
    if (head >= totalWords) head = 0; // 로테이션
    needRedraw = true;
  }
}

void pushBack(int offset) {
  int current = queue[head];
  for (int i = 0; i < offset; i++) {
    queue[head + i] = queue[head + i + 1];
  }
  queue[head + offset] = current;
}

void drawUI() {
  tft.fillScreen(TFT_BLACK);
  int idx = queue[head];
  String word = String(vocab[idx].eng);
  char firstLetter = word.charAt(0);
  if(firstLetter >= 'a') firstLetter -= 32; // 대문자 변환

  // 상단 바
  tft.fillRect(0, 0, 240, 20, TFT_NAVY);
  tft.setTextColor(TFT_WHITE);
  tft.setTextSize(1);
  tft.setCursor(10, 6);
  tft.printf("Category: [%c] | Progress: %d/%d", firstLetter, head + 1, totalWords);

  // 영단어
  tft.setTextColor(TFT_CYAN);
  tft.setTextSize(3);
  tft.setCursor(20, 45);
  tft.print(vocab[idx].eng);

  // 뜻 (한글 깨짐 주의 - 영어로 대체 권장 혹은 폰트 설정)
  tft.setTextColor(TFT_YELLOW);
  tft.setTextSize(2);
  tft.setCursor(20, 85);
  tft.print(vocab[idx].kor);

  // 하단 안내
  tft.setTextSize(1);
  tft.setTextColor(TFT_LIGHTGREY);
  tft.setCursor(10, 120);
  tft.print("Left: Forgot (Retry in 3) | Right: Next");
}
