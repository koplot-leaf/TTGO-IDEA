#include <TFT_eSPI.h>

TFT_eSPI tft = TFT_eSPI();

void setup() {
  Serial.begin(115200); // 파이썬과 속도를 맞춰야 합니다.
  tft.init();
  tft.setRotation(1);
  tft.fillScreen(TFT_BLACK);
  tft.setTextColor(TFT_CYAN);
  tft.setTextSize(2);
  tft.println("PC Monitor Ready...");
}

void loop() {
  if (Serial.available() > 0) {
    String data = Serial.readStringUntil('\n');
    
    // 데이터 분리 (CPU, RAM)
    int commaIndex = data.indexOf(',');
    if (commaIndex > 0) {
      String cpu = data.substring(0, commaIndex);
      String ram = data.substring(commaIndex + 1);

      // 화면 업데이트
      tft.fillScreen(TFT_BLACK);
      
      // CPU 섹션
      tft.setTextColor(TFT_GREEN);
      tft.setCursor(0, 10);
      tft.setTextSize(2);
      tft.print("CPU Usage:");
      tft.setCursor(0, 40);
      tft.setTextSize(4);
      tft.print(cpu + "%");

      // RAM 섹션
      tft.setTextColor(TFT_YELLOW);
      tft.setCursor(0, 80);
      tft.setTextSize(2);
      tft.print("RAM Usage:");
      tft.setCursor(0, 110);
      tft.setTextSize(4);
      tft.print(ram + "%");
    }
  }
}
