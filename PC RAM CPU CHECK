import serial
import psutil
import time

# TTGO가 연결된 포트 번호를 확인하세요 (예: 'COM3')
py_serial = serial.Serial(port='COM5', baudrate=115200)

while True:
    # CPU 사용량과 RAM 사용량 추출
    cpu_usage = int(psutil.cpu_percent())
    ram_usage = int(psutil.virtual_memory().percent)
    
    # 데이터를 "CPU,RAM\n" 형식으로 전송
    data = f"{cpu_usage},{ram_usage}\n"
    py_serial.write(data.encode())
    
    print(f"Sent: {data.strip()}")
    time.sleep(1) # 1초마다 전송


